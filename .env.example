# SalesBoost Environment Variables
# 项目基本信息
PROJECT_NAME=SalesBoost
VERSION=1.0.0
ENV_STATE=dev

# 服务器配置
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["*"]

# 硅基流动 / OpenAI 配置
OPENAI_API_KEY=sk-xxxxxx
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
MODEL_NAME=deepseek-ai/DeepSeek-V3

# AI 参数
NPC_TEMPERATURE=0.7
COACH_TEMPERATURE=0.2
